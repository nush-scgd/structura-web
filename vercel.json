import React from "react";

import { cn } from "@/lib/utils";
import { Icons } from "../../components/icons";

type SimpleButtonProps = React.ButtonHTMLAttributes<HTMLButtonElement> & {
  variant?: "default" | "outline" | "ghost";
};

function Button({ variant = "default", className = "", ...props }: SimpleButtonProps) {
  const base =
    "inline-flex items-center justify-center rounded-md px-4 py-2 text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50";

  const variants: Record<NonNullable<SimpleButtonProps["variant"]>, string> = {
    default: "bg-black text-white hover:bg-black/90",
    outline: "border border-black/15 bg-transparent hover:bg-black/5",
    ghost: "bg-transparent hover:bg-black/5",
  };

  return <button className={`${base} ${variants[variant]} ${className}`.trim()} {...props} />;
}

